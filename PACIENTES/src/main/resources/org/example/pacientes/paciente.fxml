<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="686.0" prefWidth="577.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pacientes.controlador.PacienteController">

   <children>

      <!-- CÉDULA -->
      <Label layoutX="86.0" layoutY="45.0" text="Cedula" />
      <TextField fx:id="txtCedula" layoutX="135.0" layoutY="41.0" />

      <!-- NOMBRES -->
      <Label layoutX="311.0" layoutY="45.0" text="Nombres" />
      <TextField fx:id="txtNombres" layoutX="376.0" layoutY="41.0" />

      <!-- APELLIDOS -->
      <Label layoutX="87.0" layoutY="86.0" text="Apellidos" />
      <TextField fx:id="txtApellidos" layoutX="147.0" layoutY="82.0" />

      <!-- FECHA NAC -->
      <Label layoutX="87.0" layoutY="122.0" text="Fecha de nacimiento" />
      <DatePicker fx:id="dpFecha" layoutX="235.0" layoutY="117.0" prefHeight="18.0" prefWidth="170.0" />

      <!-- GÉNERO -->
      <Label layoutX="83.0" layoutY="154.0" text="Genero" />

      <RadioButton fx:id="rbM" layoutX="150.0" layoutY="154.0" text="Masculino" />
      <RadioButton fx:id="rbF" layoutX="250.0" layoutY="154.0" text="Femenino" />

      <!-- TELÉFONO -->
      <Label layoutX="81.0" layoutY="186.0" text="Telefono" />
      <TextField fx:id="txtTelefono" layoutX="139.0" layoutY="182.0" />

      <!-- EMAIL -->
      <Label layoutX="83.0" layoutY="227.0" text="Email" />
      <TextField fx:id="txtEmail" layoutX="135.0" layoutY="226.0" />

      <!-- TIPO SANGRE -->
      <Label layoutX="81.0" layoutY="280.0" text="Tipo de sangre" />
      <ComboBox fx:id="cbSangre" layoutX="167.0" layoutY="276.0" prefWidth="150.0" />

      <!-- ALERGIAS -->
      <Label layoutX="81.0" layoutY="316.0" text="Alergias" />
      <TextArea fx:id="txtAlergias" layoutX="153.0" layoutY="312.0" prefHeight="62.0" prefWidth="200.0" />

      <!-- ACTIVO -->
      <CheckBox fx:id="chkActivo" layoutX="84.0" layoutY="385.0" text="Activo" />

      <!-- BOTONES -->
      <Button fx:id="btnGuardar" layoutX="62.0" layoutY="419.0" onAction="#guardar" text="GUARDAR" />

      <Button fx:id="btnEliminar" layoutX="186.0" layoutY="419.0" onAction="#eliminar" text="ELIMINAR" />

      <Button fx:id="btnLimpiar" layoutX="305.0" layoutY="419.0" onAction="#limpiar" text="LIMPIAR" />

      <Button fx:id="btnBuscar" layoutX="500.0" layoutY="41.0" onAction="#buscar" text="BUSCAR" />

      <!-- TABLEVIEW -->
      <TableView fx:id="tabla" layoutX="33.0" layoutY="463.0" onMouseClicked="#cargarSeleccion" prefHeight="200.0" prefWidth="476.0">

         <columns>
            <TableColumn fx:id="colCedula" prefWidth="130" text="CEDULA" />
            <TableColumn fx:id="colNombres" prefWidth="130" text="NOMBRES" />
            <TableColumn fx:id="colApellidos" prefWidth="130" text="APELLIDOS" />
         </columns>

      </TableView>
      <Label layoutX="219.0" layoutY="14.0" prefHeight="18.0" prefWidth="143.0" text="SISTEMA DE PACIENTES ">
         <font>
            <Font size="33.0" />
         </font>
      </Label>
      <Button layoutX="417.0" layoutY="416.0" mnemonicParsing="false" onAction="#buscar" text="BUSCAR" />

   </children>

</AnchorPane>
